<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="640"
        x:Class="BiomedicalSignalPlotter.PlotDisplaySettingsWindow"
        Title="Plot Display"
        Width="760"
        Height="640"
        MinWidth="680"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto"
          RowSpacing="14"
          Margin="16">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,140,Auto,100,*"
              ColumnSpacing="10"
              VerticalAlignment="Center">
            <TextBlock Grid.Column="0"
                       Text="Time window"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="TimeWindowComboBox"
                      Grid.Column="1"
                      MinWidth="140"
                      SelectionChanged="TimeWindowComboBox_SelectionChanged" />
            <TextBlock Grid.Column="2"
                       Text="Custom seconds"
                       VerticalAlignment="Center" />
            <TextBox x:Name="CustomTimeWindowTextBox"
                     Grid.Column="3" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">
                <StackPanel x:Name="Plot1Panel"
                            Spacing="6">
                    <TextBlock Text="Plot 1"
                               FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,90,90,*"
                          ColumnSpacing="10">
                        <CheckBox x:Name="Plot1AutoYCheckBox"
                                  Grid.Column="0"
                                  Content="Auto Y"
                                  Checked="AutoYCheckBox_Changed"
                                  Unchecked="AutoYCheckBox_Changed" />
                        <TextBox x:Name="Plot1YMinimumTextBox"
                                 Grid.Column="1"
                                 Watermark="Y min" />
                        <TextBox x:Name="Plot1YMaximumTextBox"
                                 Grid.Column="2"
                                 Watermark="Y max" />
                    </Grid>
                    <TextBlock Text="Reference bars use the current displayed Y-axis units."
                               FontSize="12" />
                    <StackPanel x:Name="Plot1ReferenceBarsPanel"
                                Spacing="4" />
                </StackPanel>

                <StackPanel x:Name="Plot2Panel"
                            Spacing="6">
                    <TextBlock Text="Plot 2"
                               FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,90,90,*"
                          ColumnSpacing="10">
                        <CheckBox x:Name="Plot2AutoYCheckBox"
                                  Grid.Column="0"
                                  Content="Auto Y"
                                  Checked="AutoYCheckBox_Changed"
                                  Unchecked="AutoYCheckBox_Changed" />
                        <TextBox x:Name="Plot2YMinimumTextBox"
                                 Grid.Column="1"
                                 Watermark="Y min" />
                        <TextBox x:Name="Plot2YMaximumTextBox"
                                 Grid.Column="2"
                                 Watermark="Y max" />
                    </Grid>
                    <TextBlock Text="Reference bars use the current displayed Y-axis units."
                               FontSize="12" />
                    <StackPanel x:Name="Plot2ReferenceBarsPanel"
                                Spacing="4" />
                </StackPanel>

                <StackPanel x:Name="Plot3Panel"
                            Spacing="6">
                    <TextBlock Text="Plot 3"
                               FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="Auto,90,90,*"
                          ColumnSpacing="10">
                        <CheckBox x:Name="Plot3AutoYCheckBox"
                                  Grid.Column="0"
                                  Content="Auto Y"
                                  Checked="AutoYCheckBox_Changed"
                                  Unchecked="AutoYCheckBox_Changed" />
                        <TextBox x:Name="Plot3YMinimumTextBox"
                                 Grid.Column="1"
                                 Watermark="Y min" />
                        <TextBox x:Name="Plot3YMaximumTextBox"
                                 Grid.Column="2"
                                 Watermark="Y max" />
                    </Grid>
                    <TextBlock Text="Reference bars use the current displayed Y-axis units."
                               FontSize="12" />
                    <StackPanel x:Name="Plot3ReferenceBarsPanel"
                                Spacing="4" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10">
            <TextBlock x:Name="PlotDisplayStatusText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1"
                    Content="Cancel"
                    Click="CancelButton_Click" />
            <Button Grid.Column="2"
                    Content="OK"
                    Click="OkButton_Click" />
        </Grid>
    </Grid>
</Window>
