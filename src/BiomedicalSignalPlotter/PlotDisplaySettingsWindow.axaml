<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="360"
        x:Class="BiomedicalSignalPlotter.PlotDisplaySettingsWindow"
        Title="Plot Display"
        Width="620"
        Height="360"
        MinWidth="560"
        MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*,Auto"
          RowSpacing="14"
          Margin="16">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,140,Auto,100,*"
              ColumnSpacing="10"
              VerticalAlignment="Center">
            <TextBlock Grid.Column="0"
                       Text="Time window"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="TimeWindowComboBox"
                      Grid.Column="1"
                      MinWidth="140"
                      SelectionChanged="TimeWindowComboBox_SelectionChanged" />
            <TextBlock Grid.Column="2"
                       Text="Custom seconds"
                       VerticalAlignment="Center" />
            <TextBox x:Name="CustomTimeWindowTextBox"
                     Grid.Column="3" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Spacing="8">
            <Grid ColumnDefinitions="80,Auto,90,90,*"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="Plot"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="Y axis"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="2"
                           Text="Y min"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="3"
                           Text="Y max"
                           FontWeight="SemiBold" />
            </Grid>

            <Grid x:Name="Plot1Panel"
                  ColumnDefinitions="80,Auto,90,90,*"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="Plot 1"
                           VerticalAlignment="Center" />
                <CheckBox x:Name="Plot1AutoYCheckBox"
                          Grid.Column="1"
                          Content="Auto Y"
                          Checked="AutoYCheckBox_Changed"
                          Unchecked="AutoYCheckBox_Changed" />
                <TextBox x:Name="Plot1YMinimumTextBox"
                         Grid.Column="2" />
                <TextBox x:Name="Plot1YMaximumTextBox"
                         Grid.Column="3" />
            </Grid>

            <Grid x:Name="Plot2Panel"
                  ColumnDefinitions="80,Auto,90,90,*"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="Plot 2"
                           VerticalAlignment="Center" />
                <CheckBox x:Name="Plot2AutoYCheckBox"
                          Grid.Column="1"
                          Content="Auto Y"
                          Checked="AutoYCheckBox_Changed"
                          Unchecked="AutoYCheckBox_Changed" />
                <TextBox x:Name="Plot2YMinimumTextBox"
                         Grid.Column="2" />
                <TextBox x:Name="Plot2YMaximumTextBox"
                         Grid.Column="3" />
            </Grid>

            <Grid x:Name="Plot3Panel"
                  ColumnDefinitions="80,Auto,90,90,*"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="Plot 3"
                           VerticalAlignment="Center" />
                <CheckBox x:Name="Plot3AutoYCheckBox"
                          Grid.Column="1"
                          Content="Auto Y"
                          Checked="AutoYCheckBox_Changed"
                          Unchecked="AutoYCheckBox_Changed" />
                <TextBox x:Name="Plot3YMinimumTextBox"
                         Grid.Column="2" />
                <TextBox x:Name="Plot3YMaximumTextBox"
                         Grid.Column="3" />
            </Grid>
        </StackPanel>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10">
            <TextBlock x:Name="PlotDisplayStatusText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1"
                    Content="Cancel"
                    Click="CancelButton_Click" />
            <Button Grid.Column="2"
                    Content="OK"
                    Click="OkButton_Click" />
        </Grid>
    </Grid>
</Window>
